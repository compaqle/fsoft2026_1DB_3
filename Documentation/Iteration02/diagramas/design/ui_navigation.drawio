<mxfile host="app.diagrams.net">
  <diagram name="UI-Admin" id="ui_admin">
    <mxGraphModel dx="900" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Menu Principal -->
        <mxCell id="menu_principal" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=12;fillColor=#DAE8FC;strokeColor=#6C8EBF;align=left;spacingLeft=8;" value="Menu Principal&#xa;0. ADMIN&#xa;1. CAIXA: Caixa 1&#xa;2. CAIXA: Caixa 2" vertex="1">
          <mxGeometry height="80" width="200" x="180" y="20" as="geometry" />
        </mxCell>

        <!-- Menu Admin -->
        <mxCell id="menu_admin" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=11;fillColor=#D9EAD3;strokeColor=#82B366;align=left;spacingLeft=8;" value="Menu ADMIN&#xa;1. Gerir Catálogo&#xa;2. Gerir Categorias&#xa;3. Gerir Clientes*&#xa;4. Ver Estatísticas*&#xa;0. Sair" vertex="1">
          <mxGeometry height="120" width="200" x="20" y="160" as="geometry" />
        </mxCell>

        <!-- Gerir Catalogo -->
        <mxCell id="menu_catalogo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=8;" value="Gerir Catálogo&#xa;1. Criar Produto&#xa;2. Listar Produtos&#xa;3. Editar Produto&#xa;4. Remover Produto&#xa;0. Voltar" vertex="1">
          <mxGeometry height="120" width="190" x="20" y="360" as="geometry" />
        </mxCell>

        <!-- Gerir Categorias -->
        <mxCell id="menu_categorias" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;spacingLeft=8;" value="Gerir Categorias&#xa;1. Criar Categoria&#xa;2. Listar Categorias&#xa;0. Voltar" vertex="1">
          <mxGeometry height="90" width="190" x="250" y="390" as="geometry" />
        </mxCell>

        <!-- Menu Caixa -->
        <mxCell id="menu_caixa" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=11;fillColor=#E1D5E7;strokeColor=#9673A6;align=left;spacingLeft=8;" value="Menu CAIXA&#xa;1. Realizar Venda*&#xa;2. Consultar Preço*&#xa;3. Consultar Pontos*&#xa;0. Sair" vertex="1">
          <mxGeometry height="100" width="200" x="460" y="170" as="geometry" />
        </mxCell>

        <!-- Sair -> Menu Principal -->
        <mxCell id="menu_sair" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F8CECC;strokeColor=#B85450;align=center;" value="Menu Principal" vertex="1">
          <mxGeometry height="30" width="120" x="490" y="320" as="geometry" />
        </mxCell>

        <!-- Notes -->
        <mxCell id="note" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=8;fillColor=none;strokeColor=none;align=left;" value="* Em desenvolvimento" vertex="1">
          <mxGeometry height="16" width="110" x="720" y="490" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <!-- Principal -> Admin [0] -->
        <mxCell id="arr_pa" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" value="0" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="100" as="sourcePoint" />
            <mxPoint x="120" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Principal -> Caixa [1/2] -->
        <mxCell id="arr_pc" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" value="1, 2" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="100" as="sourcePoint" />
            <mxPoint x="560" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Admin -> Catalogo [1] -->
        <mxCell id="arr_acat" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.6;exitY=1;entryX=0.5;entryY=0;" value="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="140" y="280" as="sourcePoint" />
            <mxPoint x="115" y="360" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Admin -> Categorias [2] -->
        <mxCell id="arr_acat2" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.8;exitY=0.5;entryX=0.5;entryY=0;" value="2" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="220" y="220" as="sourcePoint" />
            <mxPoint x="345" y="390" as="targetPoint" />
            <Array as="points">
              <mxPoint x="280" y="220" />
              <mxPoint x="345" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Admin -> Sair [0] -->
        <mxCell id="arr_adm_sair" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.3;exitY=1;entryX=0;entryY=0.5;" value="0" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="280" as="sourcePoint" />
            <mxPoint x="490" y="335" as="targetPoint" />
            <Array as="points">
              <mxPoint x="80" y="310" />
              <mxPoint x="400" y="310" />
              <mxPoint x="400" y="335" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Caixa -> Sair [0] -->
        <mxCell id="arr_cx_sair" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;exitX=0.3;exitY=1;entryX=1;entryY=0.5;" value="0" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="270" as="sourcePoint" />
            <mxPoint x="610" y="335" as="targetPoint" />
            <Array as="points">
              <mxPoint x="520" y="310" />
              <mxPoint x="680" y="310" />
              <mxPoint x="680" y="335" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Catalogo/Categorias -> Voltar [0] arrows go back to Admin implicitly -->
        <mxCell id="arr_cat_voltar" parent="1" style="endArrow=open;html=1;fontSize=9;endSize=8;dashed=1;" value="0 (Voltar)" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="115" y="480" as="sourcePoint" />
            <mxPoint x="115" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
